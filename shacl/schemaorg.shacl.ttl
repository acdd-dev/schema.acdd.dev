@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix acdd:    <https://schema.acdd.dev/v1.3/> .
@prefix schema:  <https://schema.org/> .
@prefix acdd:    <http://wiki.esipfed.org/ontology/acdd#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

# =============================================================================
# Top-level shape: schema:Dataset
# =============================================================================

acdd:DatasetShape
    a               sh:NodeShape ;
    sh:targetClass  schema:Dataset ;
    rdfs:label      "ACDD-aligned Dataset shape"@en ;
    rdfs:comment    "A schema:Dataset whose properties correspond to ACDD metadata attributes."@en ;

    # -------------------------------------------------------------------------
    # HIGHLY RECOMMENDED
    # -------------------------------------------------------------------------

    sh:property acdd:SchemaOrgResourceTitlePropertyShape ;
    sh:property acdd:SchemaOrgAbstractPropertyShape ;
    sh:property acdd:SchemaOrgKeywordPropertyShape ;

    # -------------------------------------------------------------------------
    # RECOMMENDED
    # -------------------------------------------------------------------------

    sh:property acdd:SchemaOrgResourceIdentifierPropertyShape ;
    sh:property acdd:SchemaOrgNamingAuthorityPropertyShape ;
    sh:property acdd:SchemaOrgKeywordVocabularyPropertyShape ;
    sh:property acdd:SchemaOrgCommonDataModelDataTypePropertyShape ;
    sh:property acdd:SchemaOrgLineageStatementPropertyShape ;
    sh:property acdd:SchemaOrgSupplementalInformationPropertyShape ;
    sh:property acdd:SchemaOrgResourceCreationRevisionDatePropertyShape ;
    sh:property acdd:SchemaOrgResourceContactPropertyShape ;
    sh:property acdd:SchemaOrgAuthorOriginatorWWWAddressPropertyShape ;
    sh:property acdd:SchemaOrgAuthorOriginatorEmailAddressPropertyShape ;
    sh:property acdd:SchemaOrgProjectNamePropertyShape ;
    sh:property acdd:SchemaOrgProcessingLevelPropertyShape ;
    sh:property acdd:SchemaOrgAcknowledgementPropertyShape ;
    sh:property acdd:SchemaOrgBoundingBoxPropertyShape ;
    sh:property acdd:SchemaOrgStartTimePropertyShape ;
    sh:property acdd:SchemaOrgEndTimePropertyShape ;
    sh:property acdd:SchemaOrgVerticalMinimumPropertyShape ;
    sh:property acdd:SchemaOrgTemporalExtentPropertyShape ;
    sh:property acdd:SchemaOrgTemporalResolutionPropertyShape ;
    sh:property acdd:SchemaOrgStandardNameVocabularyPropertyShape ;
    sh:property acdd:SchemaOrgVerticalMaximumPropertyShape ;
    sh:property acdd:SchemaOrgResourceAccessConstraintsPropertyShape ;

    # -------------------------------------------------------------------------
    # SUGGESTED
    # -------------------------------------------------------------------------

    sh:property acdd:SchemaOrgContributorNamePropertyShape ;
    sh:property acdd:SchemaOrgContributorRolePropertyShape ;
    sh:property acdd:SchemaOrgPublisherPropertyShape ;
    sh:property acdd:SchemaOrgPublisherUrlPropertyShape ;
    sh:property acdd:SchemaOrgPublisherEmailPropertyShape .


# --- resource_title → schema:name ---------------------------------------------------

acdd:SchemaOrgResourceTitlePropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:name ;
    sh:name         "Resource Title to Dataset > name" ;
    sh:description  "ACDD Resource Title to [schema:Dataset] > schema:name."@en ;
    sh:datatype     xsd:string ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:severity     sh:Warning ;
    sh:message "Resource Title is highly recommended. This should appear as `schema:name` on a `schema:Dataset`" ;
    skos:exactMatch   acdd:resource_title .

# --- abstract → schema:description ------------------------------------------

acdd:SchemaOrgAbstractPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:abstract ;
    sh:name         "Resource Title to Dataset > abstract" ;
    sh:description  "ACDD Resource Title to [schema:Dataset] > schema:abstract."@en ;
    sh:datatype     xsd:string ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:severity     sh:Warning ;
    sh:message "Abstract is highly recommended. This should appear as `schema:abstract` on a `schema:Dataset`" ;
    skos:exactMatch   acdd:abstract .

# --- keyword → schema:keywords --------------------------------------------

acdd:SchemaOrgKeywordPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:keywords ;
    sh:name         "Keyword to Dataset > keywords" ;
    sh:description  "ACDD Keyword to [schema:Dataset] > schema:keywords"@en ;
    sh:minCount     1 ;
    sh:or (
        [ sh:datatype xsd:string ]
        [ sh:class    schema:DefinedTerm ]
    ) ;
    sh:severity     sh:Warning ;
    sh:message "Keyword is highly recommended. This should appear as `schema:keywords` on a `schema:Dataset`" ;
    skos:exactMatch   acdd:keyword .

# =============================================================================
# RECOMMENDED property shapes 
# =============================================================================

# --- resource_identifier → schema:identifier ------------------------------------------------

acdd:SchemaOrgResourceIdentifierPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:identifier ;
    sh:name         "Resource Identifier to Dataset > identifier" ;
    sh:description  "ACDD Resource Identifier to [schema:Dataset] > schema:identifier."@en ;
    sh:minCount     1 ;
    sh:or (
        [ sh:datatype xsd:string ]
        [ sh:datatype xsd:anyURI ]
        [ sh:class    schema:PropertyValue ]
    ) ;
    sh:severity     sh:Warning ;
    skos:exactMatch   acdd:resource_identifier .

# --- naming_authority → schema:publisher ----------------------------------------------

acdd:SchemaOrgNamingAuthorityPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:publisher ;
    sh:name         "Naming Authority to Schema Dataset > Publisher" ;
    sh:description  "ACDD Naming Authority to [schema:Dataset] > schema:publisher."@en ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    ) ;
    sh:severity     sh:Warning ;
    skos:closeMatch   acdd:naming_authority .

# --- keyword_vocabulary → schema:publisher ----------------------------------------------

acdd:SchemaOrgKeywordVocabularyPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:keywords ;
    sh:name         "Keyword Vocabulary to Schema Dataset > keywords > inDefinedTermSet > name" ;
    sh:description  "ACDD Keyword Vocabulary to [schema:Dataset] > schema:keywords [schema:DefinedTerm] > schema:inDefinedTermSet (DefinedTermSet) > schema:name."@en ;
    sh:minCount     1 ;
    sh:class        schema:DefinedTerm ;
    sh:node         [
        a               sh:NodeShape ;
        sh:targetClass  schema:DefinedTerm ;
        
        sh:property acdd:SchemaOrgNamePropertyShape ;
        sh:property [
            a               sh:PropertyShape ;
            sh:path         schema:inDefinedTermSet ;
            sh:description  "The controlled vocabulary this keyword belongs to."@en ;
            sh:minCount     1 ;
            sh:maxCount     1 ;
            sh:class        schema:DefinedTermSet ;
            sh:node         [ 
                a               sh:NodeShape ;
                sh:targetClass  schema:DefinedTermSet ;
                sh:property     acdd:SchemaOrgNamePropertyShape ;
            ]
        ]
    ] ;
    sh:severity     sh:Warning ;
    skos:closeMatch   acdd:keyword_vocabulary .

# --- common_data_model_datatype → schema:encodingFormat ---------------------------------

acdd:SchemaOrgCommonDataModelDataTypePropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:additionalProperty ;
    sh:name         "Common Data Model Datatype to Schema Dataset > additionalProperty > propertyID(acdd:common_data_model_datatype) & value" ;
    sh:description  "ACDD Common Data Model Datatype to [schema:Dataset] > schema:additionalProperty [schema:PropertyValue] > (schema:propertyID[acdd:common_data_model_datatype] and schema:value)."@en ;
    sh:class        schema:PropertyValue ;
    sh:node         [
        a sh:NodeShape ;
        sh:property [
            sh:path     schema:propertyID ;
            sh:hasValue "https://schema.acdd.dev/v1.3/common_data_model_datatype" ;
        ] ;
        sh:property [
            sh:path     schema:value ;
            sh:datatype xsd:string ;
        ]
    ] ;
    sh:severity     sh:Warning ;
    skos:relatedMatch   acdd:common_data_model_datatype .

# --- lineage_statement → schema:additionalProperty -----------------------------------

acdd:SchemaOrgLineageStatementPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:additionalProperty ;
    sh:name         "Lineage Statement to Schema Dataset > additionalProperty > propertyID(acdd:lineage_statement) & value" ;
    sh:description  "ACDD Lineage Statement to [schema:Dataset] > schema:additionalProperty [schema:PropertyValue] > (schema:propertyID[acdd:lineage_statement] and schema:value)."@en ;
    sh:class        schema:PropertyValue ;
    sh:node         [
        a               sh:NodeShape ;
        sh:property [
            sh:path     schema:propertyID ;
            sh:hasValue "https://schema.acdd.dev/v1.3/lineage_statement" ;
        ] ;
        sh:property [
            sh:path     schema:value ;
            sh:datatype xsd:string ;
        ] 
    ] ;
    sh:severity     sh:Warning ;
    skos:relatedMatch   acdd:lineage_statement .

# --- supplemental_information → schema:description ----------------------------------------------

acdd:SchemaOrgSupplementalInformationPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:description ;
    sh:name         "Supplemental Information to Schema Dataset > description" ;
    sh:description  "ACDD Supplemental Information to [schema:Dataset] > schema:description."@en ;
    sh:datatype     xsd:string ;
    sh:severity     sh:Warning ;
    skos:relatedMatch   acdd:supplemental_information .

# --- resource_creation-revision_date → schema:datePublished -------------------------------------

acdd:SchemaOrgResourceCreationRevisionDatePropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:datePublished ;
    sh:name         "Resource Creation/Revision Date to Schema Dataset > datePublished" ;
    sh:description  "ACDD Resource Creation/Revision Date to [schema:Dataset] > schema:datePublished."@en ;
    sh:maxCount     1 ;
    sh:or (
        [ sh:datatype xsd:date ]
        [ sh:datatype xsd:dateTime ]
    ) ;
    sh:severity     sh:Warning ;
    skos:closeMatch   acdd:resource_creation-revision_date .

# --- resource_contact → schema:contactPoint -------------------------------------

acdd:SchemaOrgResourceContactPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:contactPoint ;
    sh:name         "Resource Contact to Schema Dataset > contactPoint" ;
    sh:description  "ACDD Resource Contact to [schema:Dataset] > schema:contactPoint."@en ;
    sh:minCount     1 ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    ) ;
    
    sh:severity     sh:Warning ;
    skos:closeMatch   acdd:resource_contact .


acdd:SchemaOrgAuthorOriginatorWWWAddressPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:creator ;
    sh:name         "Author / Originator WWW Address to Dataset > creator > url" ;
    sh:description  "ACDD Author / Originator to schema:Dataset > schema:creator > schema:url"@en ;
    sh:minCount     1 ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    ) ;
    sh:node         [
        a   sh:NodeShape ;
        sh:property acdd:SchemaOrgUrlPropertyShape ;
    ] ;
    sh:severity     sh:Warning ;
    skos:closeMatch   acdd:author_originator_www_address .

acdd:SchemaOrgAuthorOriginatorEmailAddressPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:creator ;
    sh:name         "Author / Originator Email Address to Dataset > creator > email" ;
    sh:description  "ACDD Author / Originator to schema:Dataset > schema:creator > schema:email"@en ;
    sh:minCount     1 ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    ) ;
    sh:node [
        a           sh:NodeShape ;
        sh:property acdd:SchemaOrgEmailPropertyShape ;
    ] ;
    sh:severity     sh:Warning ;
    skos:closeMatch acdd:author_originator_email_address .


acdd:AuthorOriginatorEmailAddressShape
    a               sh:PropertyShape ;
    sh:path         schema:creator ;
    sh:name         "Originating Organization to Dataset > creator > affiliation" ;
    sh:description  "ACDD Originating Organization to schema:Dataset > (schema:creator(schema:Organization) or schema:creator(schema:Person) > schema:affiliation"@en ;
    sh:minCount     1 ;
    sh:or (
        [ sh:node  
            [
                a               sh:NodeShape ;
                sh:targetClass  schema:Person ;

                sh:property [
                    a               sh:PropertyShape ;
                    sh:path         schema:affiliation ;
                    sh:minCount     1 ;
                    sh:class        schema:Organization ;
                    sh:node [
                        a               sh:NodeShape ;
                        sh:targetClass  schema:Organization ;
                    ]
                ] 
            ] 
        ]
        [ sh:node  
            [
                a               sh:NodeShape ;
                sh:targetClass  schema:Organization ;
                
                sh:property     acdd:SchemaOrgNamePropertyShape ;
            ] 
        ]
    ) ;
    sh:severity     sh:Warning ;
    skos:broadMatch   acdd:originating_organization .

# --- project_name → schema:isPartOf ---------------------------------------------

acdd:SchemaOrgProjectNamePropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:funding ;
    sh:name         "Project Name to Dataset > funding > (name or sponsor > name)" ;
    sh:description  "ACDD Project Name to schema:Dataset > schema:funding (schema:Grant) > (schema:name or schema:sponsor (schema:ResearchProject) > schema:name)."@en ;
    sh:node  
        [
            a               sh:NodeShape ;
            sh:targetClass  schema:Grant ;

            sh:or (
                [ sh:property   acdd:SchemaOrgNamePropertyShape ]
                [
                    sh:property [
                        a               sh:PropertyShape ;
                        sh:path         schema:sponsor ;
                        sh:minCount     1 ;
                        sh:class        schema:ResearchProject ;
                        sh:node         [
                            a           sh:NodeShape ;
                            sh:property acdd:SchemaOrgNamePropertyShape ;
                        ]
                    ]
                ]
            )

        ] ;
    sh:severity     sh:Warning ;
    skos:broadMatch   acdd:project_name .

# --- processing_level → schema:creativeWorkStatus --------------------------

acdd:SchemaOrgProcessingLevelPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:creativeWorkStatus ;
    sh:name         "processing_level to creativeWorkStatus" ;
    sh:description  "ACDD Processing Level to schema:Dataset > schema:creativeWorkStatus."@en ;
    sh:or (
        [ sh:datatype xsd:string ]
        [ sh:class    schema:DefinedTerm ]
    ) ;
    sh:severity     sh:Warning ;
    skos:relatedMatch   acdd:processing_level .

# --- acknowledgement → schema:funder  ----------------------

acdd:SchemaOrgAcknowledgementPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:funder ;
    sh:name         "acknowledgement to funder" ;
    sh:description  "ACDD Acknowledgement > schema:Dataset > schema:funder"@en ;
    sh:or (
        [ sh:class    schema:Organization ]
        [ sh:class    schema:Person ]
    ) ;
    sh:severity     sh:Warning ;
    skos:broadMatch acdd:acknowledgement .

# --- bounding_box → schema:box  ----------------------

acdd:SchemaOrgBoundingBoxPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:spatialCoverage ;
    sh:name         "bounding_box to spatialCoverage > geo > box" ;
    sh:description  "ACDD Bounding Box to schema:Dataset > schema:spatialCoverage(schema:Place) > schema:geo(schema:GeoShape) > schema:box"@en ;
    sh:class        schema:Place ;
    sh:node         [
        a               sh:NodeShape ;
        sh:targetClass  schema:Place ;
        rdfs:label      "Place with GeoShape bounding box"@en ;
        sh:property [
            sh:path     schema:geo ;
            sh:class    schema:GeoShape ;
            sh:minCount 1 ;
            sh:node     [
                a               sh:NodeShape ;
                sh:targetClass  schema:GeoShape ;
                rdfs:label      "GeoShape (bounding box)"@en ;
                sh:property [
                    sh:name         "westernmost_longitude, easternmost_longitude, southernmost_latitude, northernmost_latitude to spatialCoverage > geo > box" ;
                    sh:description  "ACDD Westernmost Longitude, Easternmost Longitude, Northernmost Latitude, Southernmost Latitude to schema:Dataset > schema:spatialCoverage(schema:Place) > schema:geo(schema:GeoShape) > schema:box"@en ;
                    sh:path        schema:box ;
                    sh:datatype    xsd:string ;
                    sh:minCount    1 ;
                    sh:maxCount    1 ;
                    sh:severity     sh:Warning ;
                    skos:closeMatch acdd:westernmost_longitude, acdd:easternmost_longitude, acdd:southernmost_latitude, acdd:northernmost_latitude ;
                ] 
            ] ;
        ]
    ] ;
    sh:severity     sh:Warning ;
    skos:closeMatch acdd:bounding_box .

# --- start_time → schema:temporalCoverage  ----------------------

acdd:SchemaOrgStartTimePropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:temporalCoverage ;
    sh:name         "start_time to temporalCoverage" ;
    sh:description  "ACDD Start Time to schema:Dataset > schema:temporalCoverage."@en ;
    sh:datatype     xsd:string ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:pattern      "^\\d{4}(-\\d{2}(-\\d{2}(T.*)?)?)?/(\\.\\.|\\d{4}(-\\d{2}(-\\d{2}(T.*)?)?)?)$" ;
    sh:severity     sh:Warning ;
    skos:closeMatch acdd:start_time .

# --- end_time → schema:temporalCoverage  ----------------------

acdd:SchemaOrgEndTimePropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:temporalCoverage ;
    sh:name         "end_time to temporalCoverage" ;
    sh:description  "ACDD End Time to schema:Dataset > schema:temporalCoverage."@en ;
    sh:datatype     xsd:string ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:pattern      "^(\\.\\.|\\d{4}(-\\d{2}(-\\d{2}(T.*)?)?)?)/\\d{4}(-\\d{2}(-\\d{2}(T.*)?)?)?$" ;
    sh:severity     sh:Warning ;
    skos:closeMatch acdd:end_time .

# --- vertical_minimum → schema:minValue  ----------------------

acdd:SchemaOrgVerticalMinimumPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:spatialCoverage ;
    sh:name         "vertical_minimum to spatialCoverage > geo > additionalProperty > minValue" ;
    sh:description  "ACDD Vertical Minimum to schema:Dataset > schema:spatialCoverage(schema:Place) > schema:geo(schema:GeoShape) > schema:additionalProperty > schema:minValue"@en ;
    sh:class        schema:Place ;
    sh:node         [
        a               sh:NodeShape ;
        sh:targetClass  schema:Place ;
        sh:property [
            sh:path     schema:geo ;
            sh:class    schema:GeoShape ;
            sh:minCount 1 ;
            sh:node     [
                a               sh:NodeShape ;
                sh:targetClass  schema:GeoShape ;
                sh:property [
                    sh:path     schema:additionalProperty ;
                    sh:class    schema:PropertyValue ;
                    sh:minCount 1 ;
                    sh:property [
                        sh:description "Some type of depth or elevation"@en ;
                        sh:path     schema:propertyID ;
                        sh:minCount 1 ;
                        sh:maxCount 1 ;
                    ] ;
                    sh:property [
                        sh:path     schema:minValue ;
                        sh:minCount 1 ;
                        sh:maxCount 1 ;
                    ]
                ] ;
            ]
        ]
    ] ;
    sh:severity     sh:Warning ;
    skos:relatedMatch acdd:vertical_minimum .

# --- vertical_maximum → schema:maxValue  ----------------------

acdd:SchemaOrgVerticalMaximumPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:spatialCoverage ;
    sh:name         "vertical_maximum to spatialCoverage > geo > additionalProperty > maxValue" ;
    sh:description  "ACDD Vertical Maximum to schema:Dataset > schema:spatialCoverage(schema:Place) > schema:geo(schema:GeoShape) > schema:additionalProperty > schema:maxValue"@en ;
    sh:class        schema:Place ;
    sh:node         [
        a               sh:NodeShape ;
        sh:targetClass  schema:Place ;
        sh:property [
            sh:path     schema:geo ;
            sh:class    schema:GeoShape ;
            sh:minCount 1 ;
            sh:node     [
                a               sh:NodeShape ;
                sh:targetClass  schema:GeoShape ;
                sh:property [
                    sh:path     schema:additionalProperty ;
                    sh:class    schema:PropertyValue ;
                    sh:minCount 1 ;
                    sh:property [
                        sh:description "Some type of depth or elevation"@en ;
                        sh:path     schema:propertyID ;
                        sh:minCount 1 ;
                        sh:maxCount 1 ;
                    ] ;
                    sh:property [
                        sh:path     schema:maxValue ;
                        sh:minCount 1 ;
                        sh:maxCount 1 ;
                    ]
                ] ;
            ]
        ]
    ] ;
    sh:severity     sh:Warning ;
    skos:relatedMatch acdd:vertical_maximum .

# --- temporal_extent → schema:temporalCoverage  ----------------------

acdd:SchemaOrgTemporalExtentPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:temporalCoverage ;
    sh:name         "temporal_extent to temporalCoverage" ;
    sh:description  "ACDD Temporal Extent to schema:Dataset > schema:temporalCoverage"@en ;
    sh:datatype     xsd:string ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:severity     sh:Warning ;
    skos:exactMatch acdd:temporal_extent .

# --- temporal_resolution → schema:additionalProperty ---------------------------------

acdd:SchemaOrgTemporalResolutionPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:additionalProperty ;
    sh:name         "temporal_resolution to additionalProperty" ;
    sh:description  "ACDD Temporal Resolution to schema:Dataset > schema:additionalProperty"@en ;
    sh:class        schema:PropertyValue ;
    sh:node [
        a sh:NodeShape ;
        sh:property [ sh:path schema:propertyID ; sh:hasValue "https://schema.acdd.dev/v1.0/temporal_resolution" ] ;
        sh:property [ sh:path schema:value ; sh:datatype xsd:string ] ;
    ] ;
    sh:severity     sh:Warning ;
    skos:relatedMatch acdd:temporal_resolution .

# --- standard_name_vocabulary → schema:additionalProperty ---------------------------------

acdd:SchemaOrgStandardNameVocabularyPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:additionalProperty ;
    sh:name         "standard_name_vocabulary to additionalProperty" ;
    sh:description  "ACDD Standard Name Vocabulary to schema:Dataset > schema:additionalProperty"@en ;
    sh:class        schema:PropertyValue ;
    sh:node [
        a sh:NodeShape ;
        sh:property [ sh:path schema:propertyID ; sh:hasValue "https://schema.acdd.dev/v1.0/standard_name_vocabulary" ] ;
        sh:property [ sh:path schema:value ; sh:datatype xsd:string ] ;
    ] ;
    sh:severity     sh:Warning ;
    skos:relatedMatch acdd:standard_name_vocabulary .

# --- resource_access_constraints → schema:license ----------------------------------------------

acdd:SchemaOrgResourceAccessConstraintsPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:license ;
    sh:name         "resource_access_constraints" ;
    sh:description  "ACDD Resource Access Constraints to schema:Dataset > schema:license."@en ;
    sh:or (
        [ sh:datatype xsd:string ]
        [ sh:datatype xsd:anyURI ]
        [ sh:class    schema:CreativeWork ]
    ) ;
    sh:severity     sh:Warning ;
    skos:broadMatch acdd:resource_access_constraints .


# =============================================================================
# SUGGESTED – Contributor (nested structure)
# =============================================================================
# Maps: acdd:contributor_name, acdd:contributor_role

# --- contributor_name → schema:name ----------------------------------------------

acdd:SchemaOrgContributorNamePropertyShape
    a               sh:PropertyShape ;
    sh:or (
        [ sh:path   schema:creator ]
        [ sh:path   schema:contributor ]
    ) ;
    sh:name         "contributor_name to Dataset > creator or contributor > name" ;
    sh:description  "ACDD Contributor Name to schema:Dataset > (schema:creator or schema:contributor(schema:Person or schema:Organization)) > schema:name."@en ;
    sh:or (
        [ sh:class schema:Person ]
        [ sh:class schema:Organization ]
    ) ;
    sh:node [
        a           sh:NodeShape ;
        sh:property acdd:SchemaOrgNamePropertyShape ;
    ] ;
    sh:severity     sh:Info ;
    skos:exactMatch acdd:contributor_name .
    
# --- contributor_role → schema:roleName ----------------------------------------------

acdd:SchemaOrgContributorRolePropertyShape
    a               sh:PropertyShape ;
    sh:or (
        [ sh:path   schema:creator ]
        [ sh:path   schema:contributor ]
    ) ;
    sh:name         "contributor_role to Dataset > creator or contributor > roleName" ;
    sh:description  "ACDD Contributor Role to schema:Dataset > (schema:creator or schema:contributor(schema:Role)) > schema:roleName."@en ;
    sh:class schema:Role;
    sh:node [
        a               sh:NodeShape ;
        sh:property [
            sh:path     schema:roleName ;
            sh:datatype xsd:string ;
            sh:minCount 1 ;
        ]
    ] ;
    sh:severity     sh:Info ;
    skos:exactMatch acdd:contributor_role .

# --- publisher → schema:publisher ----------------------------------------------

acdd:SchemaOrgPublisherPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:publisher ;
    sh:name         "publisher to publisher > name" ;
    sh:description  "ACDD Publisher to schema:Dataset > schema:publisher > schema:name."@en ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    );
    sh:node [
        a           sh:NodeShape ;
        sh:property acdd:SchemaOrgNamePropertyShape ;
    ] ;
    sh:severity     sh:Info ;
    skos:exactMatch acdd:publisher .

# --- publisher_url → schema:publisher ----------------------------------------------

acdd:SchemaOrgPublisherUrlPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:publisher ;
    sh:name         "publisher_url to publisher > url" ;
    sh:description  "ACDD Publisher URL to schema:Dataset > schema:publisher > schema:url."@en ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    );
    sh:node         [
        a   sh:NodeShape ;
        sh:property acdd:SchemaOrgUrlPropertyShape ;
    ] ;
    sh:severity     sh:Info ;
    skos:exactMatch acdd:publisher_url .

# --- publisher_email → schema:publisher ----------------------------------------------

acdd:SchemaOrgPublisherEmailPropertyShape
    a               sh:PropertyShape ;
    sh:path         schema:publisher ;
    sh:name         "publisher_email to publisher > email" ;
    sh:description  "ACDD Publisher E-Mail to schema:Dataset > schema:publisher > schema:email."@en ;
    sh:or (
        [ sh:class  schema:Organization ]
        [ sh:class  schema:Person ]
    );
    sh:node         acdd:SchemaOrgEmailPropertyShape ;
    sh:severity     sh:Info ;
    skos:exactMatch acdd:publisher_email .


# -------------------------------------------------------------------------
# SUPPORTING SHAPES
# -------------------------------------------------------------------------

acdd:SchemaOrgNamePropertyShape
    a   sh:PropertyShape ;
    sh:property [
        sh:path     schema:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .

acdd:SchemaOrgEmailPropertyShape
    a   sh:PropertyShape ;
    sh:property [
        sh:path     schema:email ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ]  .

acdd:SchemaOrgUrlPropertyShape
    a   sh:PropertyShape ;
    sh:property [
        sh:path     schema:url ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .