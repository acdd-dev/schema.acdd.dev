<?xml version="1.0"?>
<rdf:RDF xmlns="https://schema.acdd.dev/v1.3#"
     xml:base="https://schema.acdd.dev/v1.3"
     xmlns:v1="https://schema.acdd.dev/v1.3#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://schema.acdd.dev/v1.3#">
        <owl:versionIRI rdf:resource="https://schema.acdd.dev/v1.3#"/>
        <terms:creator>Earth Science Information Partners (ESIP)</terms:creator>
        <terms:description xml:lang="en">An OWL ontology encoding the ESIP Attribute Convention for Data Discovery (ACDD). It formalises the concepts, recommendation levels, and metadata properties defined at https://wiki.esipfed.org/Data_Discovery_(ACDD).</terms:description>
        <terms:license rdf:resource="http://www.gnu.org/copyleft/fdl.html"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2016-11-15</terms:modified>
        <terms:source rdf:resource="https://wiki.esipfed.org/Data_Discovery_(ACDD)"/>
        <terms:title xml:lang="en">Attribute Convention for Data Discovery (ACDD) Ontology</terms:title>
        <vann:preferredNamespacePrefix>acdd</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://wiki.esipfed.org/ontology/acdd#</vann:preferredNamespaceUri>
        <owl:versionInfo>1.3</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/source -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- https://schema.acdd.dev/v1.3#recommendationLevel -->


    <owl:AnnotationProperty rdf:about="https://schema.acdd.dev/v1.3#recommendationLevel">
        <rdfs:comment xml:lang="en">Links an ACDD property to its recommendation level.</rdfs:comment>
        <rdfs:label xml:lang="en">recommendation level</rdfs:label>
        <rdfs:range rdf:resource="https://schema.acdd.dev/v1.3#RecommendationLevel"/>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#duration -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#duration"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://schema.acdd.dev/v1.3#abstract -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#abstract">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A paragraph describing the resource. Also referred to as &apos;Description&apos; in Catalog Services for the Web.</rdfs:comment>
        <rdfs:label xml:lang="en">Abstract</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Abstract"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#HighlyRecommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#acknowledgement -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#acknowledgement">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provides a place to acknowledge various types of support for the project that produced the data.</rdfs:comment>
        <rdfs:label xml:lang="en">Acknowledgement</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Acknowledgement"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#author_originator_email_address -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#author_originator_email_address">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The electronic mail address of the principal author of the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Author / Originator Email Address</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Author_/_Originator_Email_Address"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#author_originator_www_address -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#author_originator_www_address">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">The World Wide Web address of the principal author of the cited resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Author / Originator World Wide Web Address</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Author_/_Originator_World_Wide_Web_Address"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#bounding_box -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#bounding_box">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A bounding box for identifying a geographic area of interest. Note: This concept is called &quot;Coverage&quot; in the CSW Specification.</rdfs:comment>
        <rdfs:label xml:lang="en">Bounding Box</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Bounding_Box"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#common_data_model_datatype -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#common_data_model_datatype">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The THREDDS data type for this resource. Current values: vector, grid, textTable, tin, stereoModel, video.</rdfs:comment>
        <rdfs:label xml:lang="en">Common Data Model Datatype</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Common_Data_Model_Datatype"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#contributor_name -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#contributor_name">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of a contributor to the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Contributor Name</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Contributor_Name"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Suggested"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#contributor_role -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#contributor_role">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The role of any individuals or institutions that contributed to the creation of the data.</rdfs:comment>
        <rdfs:label xml:lang="en">Contributor Role</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Contributor_Role"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Suggested"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#easternmost_longitude -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#easternmost_longitude">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The easternmost longitude of the bounding rectangle.</rdfs:comment>
        <rdfs:label xml:lang="en">Easternmost Longitude</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Easternmost_Longitude"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#end_time -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#end_time">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The end of the bounding time period.</rdfs:comment>
        <rdfs:label xml:lang="en">End Time</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#End_Time"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#keyword -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#keyword">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A word or phrase that describes some aspect of a resource. Can be one of several types.</rdfs:comment>
        <rdfs:label xml:lang="en">Keyword</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Keyword"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#HighlyRecommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#keyword_vocabulary -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#keyword_vocabulary">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">If you are following a guideline or using a shared vocabulary for the words/phrases in your keywords attribute, put the name of that guideline here.</rdfs:comment>
        <rdfs:label xml:lang="en">Keyword Vocabulary</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Keyword_Vocabulary"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#lineage_statement -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#lineage_statement">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Information and references for sources and processes that were used to create the dataset and an audit trail for modifications to the original data.</rdfs:comment>
        <rdfs:label xml:lang="en">Lineage Statement</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Lineage_Statement"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#naming_authority -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#naming_authority">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The organization responsible for the maintenance of the identifier (namespace).</rdfs:comment>
        <rdfs:label xml:lang="en">Naming Authority</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Naming_Authority"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#northernmost_latitude -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#northernmost_latitude">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The northernmost latitude of the bounding rectangle.</rdfs:comment>
        <rdfs:label xml:lang="en">Northernmost Latitude</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Northernmost_Latitude"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#originating_organization -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#originating_organization">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The organization responsible for creating the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Originating Organization</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Originating_Organization"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#processing_level -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#processing_level">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A code that indicates the extent of processing done in the creation of a dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Processing Level</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Processing_Level"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#project_name -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#project_name">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of the project that the resource was associated with.</rdfs:comment>
        <rdfs:label xml:lang="en">Project Name</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Project_Name"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#publisher -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#publisher">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Publisher of the cited resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Publisher</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Publisher"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Suggested"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#publisher_email -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#publisher_email">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Email associated with the publisher of the cited resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Publisher E-Mail</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Publisher_E-Mail"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Suggested"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#publisher_url -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#publisher_url">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">World Wide Web address associated with the publisher of the cited resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Publisher URL</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Publisher_URL"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Suggested"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#resource_access_constraints -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#resource_access_constraints">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Information about any constraints for accessing the data set. This includes any special restrictions, legal prerequisites, limitations and/or warnings on obtaining the data set.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource Access Constraints</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Resource_Access_Constraints"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#resource_contact -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#resource_contact">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The organization or person responsible for answering questions about the resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource Contact</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Resource_Contact"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#resource_creation-revision_date -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#resource_creation-revision_date">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The date the resource was created.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource Creation/Revision Date</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Resource_Creation/Revision_Date"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#resource_identifier -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#resource_identifier">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier for the resource described by the metadata.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource Identifier</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Resource_Identifier"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#Recommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#resource_title -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#resource_title">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A short description of the resource. The title should be descriptive enough so that when a user is presented with a list of titles the general content of the data set can be determined.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource Title</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://wiki.esipfed.org/Concepts_Glossary#Resource_Title"/>
        <recommendationLevel rdf:resource="https://schema.acdd.dev/v1.3#HighlyRecommended"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.acdd.dev/v1.3#southernmost_latitude -->


    <owl:DatatypeProperty rdf:about="https://schema.acdd.dev/v1.3#southernmost_latitude">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
