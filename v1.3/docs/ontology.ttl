                    rdfs:range xsd:string ;
                    rdfs:comment "If you are following a guideline or using a shared vocabulary for the words/phrases in your keywords attribute, put the name of that guideline here."@en ;
                    rdfs:label "Keyword Vocabulary"@en ;
