<https://schema.acdd.dev/v1.3#> rdf:type owl:Ontology ;
                                 owl:versionIRI <https://schema.acdd.dev/v1.3#> ;
                                 <http://purl.org/dc/terms/creator> "Earth Science Information Partners (ESIP)" ;
                                 <http://purl.org/dc/terms/description> "An OWL ontology encoding the ESIP Attribute Convention for Data Discovery (ACDD). It formalises the concepts, recommendation levels, and metadata properties defined at https://wiki.esipfed.org/Data_Discovery_(ACDD)."@en ;
