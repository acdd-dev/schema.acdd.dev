:easternmost_longitude rdf:type owl:DatatypeProperty ;
                       rdfs:domain owl:Thing ;
                       rdfs:range xsd:double ;
                       rdfs:comment "The easternmost longitude of the bounding rectangle."@en ;
                       rdfs:label "Easternmost Longitude"@en ;
                       rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Easternmost_Longitude> ;
                       :recommendationLevel :Recommended .


