###  https://schema.acdd.dev/v1.3#recommendationLevel
:recommendationLevel rdf:type owl:AnnotationProperty ;
                     rdfs:comment "Links an ACDD property to its recommendation level."@en ;
                     rdfs:label "recommendation level"@en ;
                     rdfs:range :RecommendationLevel .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#duration
xsd:duration rdf:type rdfs:Datatype .


#################################################################
#    Data properties
#################################################################

###  https://schema.acdd.dev/v1.3#abstract
:abstract rdf:type owl:DatatypeProperty ;
          rdfs:domain owl:Thing ;
          rdfs:range xsd:string ;
          rdfs:comment "A paragraph describing the resource. Also referred to as 'Description' in Catalog Services for the Web."@en ;
          rdfs:label "Abstract"@en ;
          rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Abstract> ;
          :recommendationLevel :HighlyRecommended .


###  https://schema.acdd.dev/v1.3#acknowledgement
:acknowledgement rdf:type owl:DatatypeProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Provides a place to acknowledge various types of support for the project that produced the data."@en ;
                 rdfs:label "Acknowledgement"@en ;
                 rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Acknowledgement> ;
                 :recommendationLevel :Recommended .


###  https://schema.acdd.dev/v1.3#author_originator_email_address
:author_originator_email_address rdf:type owl:DatatypeProperty ;
                                 rdfs:domain owl:Thing ;
                                 rdfs:range xsd:string ;
                                 rdfs:comment "The electronic mail address of the principal author of the resource."@en ;
                                 rdfs:label "Author / Originator Email Address"@en ;
                                 rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Author_/_Originator_Email_Address> ;
                                 :recommendationLevel :Recommended .


###  https://schema.acdd.dev/v1.3#author_originator_www_address
:author_originator_www_address rdf:type owl:DatatypeProperty ;
                               rdfs:domain owl:Thing ;
                               rdfs:range xsd:anyURI ;
                               rdfs:comment "The World Wide Web address of the principal author of the cited resource."@en ;
                               rdfs:label "Author / Originator World Wide Web Address"@en ;
                               rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Author_/_Originator_World_Wide_Web_Address> ;
                               :recommendationLevel :Recommended .


###  https://schema.acdd.dev/v1.3#bounding_box
:bounding_box rdf:type owl:DatatypeProperty ;
              rdfs:domain owl:Thing ;
              rdfs:range xsd:string ;
              rdfs:comment "A bounding box for identifying a geographic area of interest. Note: This concept is called \"Coverage\" in the CSW Specification."@en ;
              rdfs:label "Bounding Box"@en ;
              rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Bounding_Box> ;
              :recommendationLevel :Recommended .


###  https://schema.acdd.dev/v1.3#common_data_model_datatype
:common_data_model_datatype rdf:type owl:DatatypeProperty ;
                            rdfs:domain owl:Thing ;
                            rdfs:range xsd:string ;
                            rdfs:comment "The THREDDS data type for this resource. Current values: vector, grid, textTable, tin, stereoModel, video."@en ;
                            rdfs:label "Common Data Model Datatype"@en ;
                            rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Common_Data_Model_Datatype> ;
                            :recommendationLevel :Recommended .


###  https://schema.acdd.dev/v1.3#contributor_name
:contributor_name rdf:type owl:DatatypeProperty ;
                  rdfs:domain owl:Thing ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The name of a contributor to the resource."@en ;
                  rdfs:label "Contributor Name"@en ;
                  rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Contributor_Name> ;
                  :recommendationLevel :Suggested .


###  https://schema.acdd.dev/v1.3#contributor_role
:contributor_role rdf:type owl:DatatypeProperty ;
                  rdfs:domain owl:Thing ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The role of any individuals or institutions that contributed to the creation of the data."@en ;
                  rdfs:label "Contributor Role"@en ;
                  rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Contributor_Role> ;
                  :recommendationLevel :Suggested .


