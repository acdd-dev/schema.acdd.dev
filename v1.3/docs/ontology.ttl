                                 <http://purl.org/dc/terms/title> "Attribute Convention for Data Discovery (ACDD) Ontology"@en ;
                                 <http://purl.org/vocab/vann/preferredNamespacePrefix> "acdd" ;
                                 <http://purl.org/vocab/vann/preferredNamespaceUri> "http://wiki.esipfed.org/ontology/acdd#" ;
                                 owl:versionInfo "1.3" .

