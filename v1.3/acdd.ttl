                         rdfs:label "Recommendation Level"@en .


#################################################################
#    Individuals
#################################################################

###  https://schema.acdd.dev/v1.3#HighlyRecommended
acdd:HighlyRecommended rdf:type owl:NamedIndividual ,
                                acdd:RecommendationLevel ;
                       rdfs:comment "Attributes that are highly recommended by the ACDD."@en ;
                       rdfs:label "Highly Recommended"@en .


###  https://schema.acdd.dev/v1.3#Recommended
acdd:Recommended rdf:type owl:NamedIndividual ,
                          acdd:RecommendationLevel ;
