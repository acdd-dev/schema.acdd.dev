@prefix : <https://schema.acdd.dev/v1.3/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix acdd: <https://schema.acdd.dev/v1.3/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@base <https://schema.acdd.dev/v1.3/> .

<https://schema.acdd.dev/v1.3/> rdf:type owl:Ontology ;
                                 owl:versionIRI <https://schema.acdd.dev/v1.3/> ;
                                 dct:creator "Earth Science Information Partners (ESIP)" ;
                                 dct:description "An OWL ontology encoding the ESIP Attribute Convention for Data Discovery (ACDD). It formalises the concepts, recommendation levels, and metadata properties defined at https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3."@en ;
                                 dct:license "http://www.gnu.org/copyleft/fdl.html"^^xsd:anyURI ;
                                 dct:modified "2023-09-05"^^xsd:date ;
                                 dct:source "https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3"^^xsd:anyURI ;
                                 dct:title "Attribute Convention for Data Discovery (ACDD) Ontology"@en ;
                                 vann:preferredNamespacePrefix "acdd" ;
                                 vann:preferredNamespaceUri "https://schema.acdd.dev/v1.3/" ;
                                 owl:versionInfo "1.3" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
dct:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dct:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dct:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
dct:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/subject
dct:subject rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  https://schema.acdd.dev/v1.3/recommendationLevel
acdd:recommendationLevel rdf:type owl:AnnotationProperty ;
                         rdfs:comment "Links an ACDD property to its recommendation level."@en ;
                         rdfs:label "recommendation level"@en ;
                         rdfs:range acdd:RecommendationLevel .


#################################################################
#    Data properties
#################################################################

###  https://schema.acdd.dev/v1.3/acknowledgement
acdd:acknowledgement rdf:type owl:DatatypeProperty ;
                     rdfs:domain owl:Thing ;
                     rdfs:range xsd:string ;
                     dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#acknowledgement> ;
                     rdfs:comment "A place to acknowledge various types of support for the project that produced this data."@en ;
                     rdfs:label "acknowledgement"@en ;
                     acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/cdm_data_type
acdd:cdm_data_type rdf:type owl:DatatypeProperty ;
                   rdfs:domain owl:Thing ;
                   rdfs:range xsd:string ;
                   dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#cdm_data_type> ;
                   rdfs:comment "The data type, as derived from Unidata's Common Data Model Scientific Data types and understood by THREDDS. (This is a THREDDS \"dataType\", and is different from the CF NetCDF attribute 'featureType', which indicates a Discrete Sampling Geometry file in CF.)"@en ;
                   rdfs:label "cdm_data_type"@en ;
                   acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/comment
acdd:comment rdf:type owl:DatatypeProperty ;
             rdfs:domain owl:Thing ;
             rdfs:range xsd:string ;
             dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#comment> ;
             rdfs:comment "Miscellaneous information about the data, not captured elsewhere. This attribute is defined in the CF Conventions."@en ;
             rdfs:label "comment"@en ;
             acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/contributor_name
acdd:contributor_name rdf:type owl:DatatypeProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range xsd:string ;
                      dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#contributor_name> ;
                      rdfs:comment "The name of any individuals, projects, or institutions that contributed to the creation of this data. May be presented as free text, or in a structured format compatible with conversion to ncML (e.g., insensitive to changes in whitespace, including end-of-line characters)."@en ;
                      rdfs:label "contributor_name"@en ;
                      acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/contributor_role
acdd:contributor_role rdf:type owl:DatatypeProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range xsd:string ;
                      dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#contributor_role> ;
                      rdfs:comment "The role of any individuals, projects, or institutions that contributed to the creation of this data. May be presented as free text, or in a structured format compatible with conversion to ncML (e.g., insensitive to changes in whitespace, including end-of-line characters). Multiple roles should be presented in the same order and number as the names in contributor_names."@en ;
                      rdfs:label "contributor_role"@en ;
                      acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/conventions
acdd:conventions rdf:type owl:DatatypeProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range xsd:string ;
                 dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#keywords> ;
                 rdfs:comment "A comma-separated list of the conventions that are followed by the dataset. For files that follow this version of ACDD, include the string 'ACDD-1.3'. "@en ;
                 rdfs:label "Conventions"@en ;
                 acdd:recommendationLevel acdd:Dataset_HighlyRecommended .


###  https://schema.acdd.dev/v1.3/coverage_content_type
acdd:coverage_content_type rdf:type owl:DatatypeProperty ;
                           dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#coverage_content_type> ;
                           rdfs:comment "An ISO 19115-1 code to indicate the source of the data (image, thematicClassification, physicalMeasurement, auxiliaryInformation, qualityInformation, referenceInformation, modelResult, or coordinate)." ;
                           rdfs:label "coverage_content_type" ;
                           acdd:recommendationLevel acdd:Variable_HighlyRecommended .


###  https://schema.acdd.dev/v1.3/creator_email
acdd:creator_email rdf:type owl:DatatypeProperty ;
                   rdfs:domain owl:Thing ;
                   rdfs:range xsd:string ;
                   dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#creator_email> ;
                   rdfs:comment "The email address of the person (or other creator type specified by the creator_type attribute) principally responsible for creating this data."@en ;
                   rdfs:label "creator_email"@en ;
                   acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/creator_institution
acdd:creator_institution rdf:type owl:DatatypeProperty ;
                         rdfs:domain owl:Thing ;
                         rdfs:range xsd:string ;
                         dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#creator_institution> ;
                         rdfs:comment "The institution of the creator; should uniquely identify the creator's institution. This attribute's value should be specified even if it matches the value of publisher_institution, or if creator_type is institution."@en ;
                         rdfs:label "creator_institution"@en ;
                         acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/creator_name
acdd:creator_name rdf:type owl:DatatypeProperty ;
                  rdfs:domain owl:Thing ;
                  rdfs:range xsd:string ;
                  dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#creator_name> ;
                  rdfs:comment "The name of the person (or other creator type specified by the creator_type attribute) principally responsible for creating this data."@en ;
                  rdfs:label "creator_name"@en ;
                  acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/creator_type
acdd:creator_type rdf:type owl:DatatypeProperty ;
                  rdfs:domain owl:Thing ;
                  rdfs:range xsd:string ;
                  dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#creator_type> ;
                  rdfs:comment "Specifies type of creator with one of the following: 'person', 'group', 'institution', or 'position'. If this attribute is not specified, the creator is assumed to be a person."@en ;
                  rdfs:label "creator_type"@en ;
                  acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/creator_url
acdd:creator_url rdf:type owl:DatatypeProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range xsd:anyURI ;
                 dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#creator_url> ;
                 rdfs:comment "The URL of the person (or other creator type specified by the creator_type attribute) principally responsible for creating this data."@en ;
                 rdfs:label "creator_url"@en ;
                 acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/date_created
acdd:date_created rdf:type owl:DatatypeProperty ;
                  rdfs:domain owl:Thing ;
                  rdfs:range [ rdf:type rdfs:Datatype ;
                               owl:unionOf ( xsd:date
                                             xsd:string
                                           )
                             ] ;
                  dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#date_created> ;
                  rdfs:comment "The date on which this version of the data was created. (Modification of values implies a new version, hence this would be assigned the date of the most recent values modification.) Metadata changes are not considered when assigning the date_created. The ISO 8601:2004 extended date format is recommended, as described in the Attribute Content Guidance section."@en ;
                  rdfs:label "date_created"@en ;
                  acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/date_issued
acdd:date_issued rdf:type owl:DatatypeProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range [ rdf:type rdfs:Datatype ;
                              owl:unionOf ( xsd:date
                                            xsd:string
                                          )
                            ] ;
                 dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#date_issued> ;
                 rdfs:comment "The date on which this data (including all modifications) was formally issued (i.e., made available to a wider audience). Note that these apply just to the data, not the metadata. The ISO 8601:2004 extended date format is recommended, as described in the Attributes Content Guidance section."@en ;
                 rdfs:label "date_issued"@en ;
                 acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/date_metadata_modified
acdd:date_metadata_modified rdf:type owl:DatatypeProperty ;
                            rdfs:domain owl:Thing ;
                            rdfs:range [ rdf:type rdfs:Datatype ;
                                         owl:unionOf ( xsd:date
                                                       xsd:string
                                                     )
                                       ] ;
                            dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#date_metadata_modified> ;
                            rdfs:comment "The date on which the metadata was last modified. The ISO 8601:2004 extended date format is recommended, as described in the Attributes Content Guidance section."@en ;
                            rdfs:label "date_metadata_modified"@en ;
                            acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/date_modified
acdd:date_modified rdf:type owl:DatatypeProperty ;
                   rdfs:domain owl:Thing ;
                   rdfs:range [ rdf:type rdfs:Datatype ;
                                owl:unionOf ( xsd:date
                                              xsd:string
                                            )
                              ] ;
                   dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#date_modified> ;
                   rdfs:comment "The date on which the data was last modified. Note that this applies just to the data, not the metadata. The ISO 8601:2004 extended date format is recommended, as described in the Attributes Content Guidance section."@en ;
                   rdfs:label "date_modified"@en ;
                   acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/geospatial_bounds
acdd:geospatial_bounds rdf:type owl:DatatypeProperty ;
                       rdfs:domain owl:Thing ;
                       rdfs:range xsd:string ;
                       dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_bounds> ;
                       rdfs:comment "Describes the data's 2D or 3D geospatial extent in OGC's Well-Known Text (WKT) Geometry format (reference the OGC Simple Feature Access (SFA) specification). The meaning and order of values for each point's coordinates depends on the coordinate reference system (CRS). The ACDD default is 2D geometry in the EPSG:4326 coordinate reference system. The default may be overridden with geospatial_bounds_crs and geospatial_bounds_vertical_crs (see those attributes). EPSG:4326 coordinate values are latitude (decimal degrees_north) and longitude (decimal degrees_east), in that order. Longitude values in the default case are limited to the [-180, 180) range. Example: 'POLYGON ((40.26 -111.29, 41.26 -111.29, 41.26 -110.29, 40.26 -110.29, 40.26 -111.29))'."@en ;
                       rdfs:label "geospatial_bounds"@en ;
                       acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_bounds_crs
acdd:geospatial_bounds_crs rdf:type owl:DatatypeProperty ;
                           rdfs:domain owl:Thing ;
                           rdfs:range xsd:string ;
                           dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_bounds_crs> ;
                           rdfs:comment "The coordinate reference system (CRS) of the point coordinates in the geospatial_bounds attribute. This CRS may be 2-dimensional or 3-dimensional, but together with geospatial_bounds_vertical_crs, if that attribute is supplied, must match the dimensionality, order, and meaning of point coordinate values in the geospatial_bounds attribute. If geospatial_bounds_vertical_crs is also present then this attribute must only specify a 2D CRS. EPSG CRSs are strongly recommended. If this attribute is not specified, the CRS is assumed to be EPSG:4326. Examples: 'EPSG:4979' (the 3D WGS84 CRS), 'EPSG:4047'."@en ;
                           rdfs:label "geospatial_bounds_crs"@en ;
                           acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_bounds_vertical_crs
acdd:geospatial_bounds_vertical_crs rdf:type owl:DatatypeProperty ;
                                    rdfs:domain owl:Thing ;
                                    rdfs:range xsd:string ;
                                    dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_bounds_vertical_crs> ;
                                    rdfs:comment "The vertical coordinate reference system (CRS) for the Z axis of the point coordinates in the geospatial_bounds attribute. This attribute cannot be used if the CRS in geospatial_bounds_crs is 3-dimensional; to use this attribute, geospatial_bounds_crs must exist and specify a 2D CRS. EPSG CRSs are strongly recommended. There is no default for this attribute when not specified. Examples: 'EPSG:5829' (instantaneous height above sea level), \"EPSG:5831\" (instantaneous depth below sea level), or 'EPSG:5703' (NAVD88 height)."@en ;
                                    rdfs:label "geospatial_bounds_vertical_crs"@en ;
                                    acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_lat_max
acdd:geospatial_lat_max rdf:type owl:DatatypeProperty ;
                        rdfs:domain owl:Thing ;
                        rdfs:range [ rdf:type rdfs:Datatype ;
                                     owl:unionOf ( xsd:double
                                                   xsd:string
                                                 )
                                   ] ;
                        dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lat_max> ;
                        rdfs:comment "Describes a simple upper latitude limit; may be part of a 2- or 3-dimensional bounding region. Geospatial_lat_max specifies the northernmost latitude covered by the dataset."@en ;
                        rdfs:label "geospatial_lat_max"@en ;
                        acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_lat_min
acdd:geospatial_lat_min rdf:type owl:DatatypeProperty ;
                        rdfs:domain owl:Thing ;
                        rdfs:range [ rdf:type rdfs:Datatype ;
                                     owl:unionOf ( xsd:double
                                                   xsd:string
                                                 )
                                   ] ;
                        dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lat_min> ;
                        rdfs:comment "Describes a simple lower latitude limit; may be part of a 2- or 3-dimensional bounding region. Geospatial_lat_min specifies the southernmost latitude covered by the dataset."@en ;
                        rdfs:label "geospatial_lat_min"@en ;
                        acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_lat_resolution
acdd:geospatial_lat_resolution rdf:type owl:DatatypeProperty ;
                               rdfs:domain owl:Thing ;
                               rdfs:range xsd:string ;
                               dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lat_resolution> ;
                               rdfs:comment "Information about the targeted spacing of points in latitude. Recommend describing resolution as a number value followed by the units. Examples: '100 meters', '0.1 degree'"@en ;
                               rdfs:label "geospatial_lat_resolution"@en ;
                               acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/geospatial_lat_units
acdd:geospatial_lat_units rdf:type owl:DatatypeProperty ;
                          rdfs:domain owl:Thing ;
                          rdfs:range xsd:string ;
                          dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lat_units> ;
                          rdfs:comment "Units for the latitude axis described in \"geospatial_lat_min\" and \"geospatial_lat_max\" attributes. These are presumed to be \"degree_north\"; other options from udunits may be specified instead."@en ;
                          rdfs:label "geospatial_lat_units"@en ;
                          acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/geospatial_lon_max
acdd:geospatial_lon_max rdf:type owl:DatatypeProperty ;
                        rdfs:domain owl:Thing ;
                        rdfs:range xsd:double ;
                        dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lon_max> ;
                        rdfs:comment "Describes a simple longitude limit; may be part of a 2- or 3-dimensional bounding region. geospatial_lon_max specifies the easternmost longitude covered by the dataset. Cases where geospatial_lon_min is greater than geospatial_lon_max indicate the bounding box extends from geospatial_lon_max, through the longitude range discontinuity meridian (either the antimeridian for -180:180 values, or Prime Meridian for 0:360 values), to geospatial_lon_min; for example, geospatial_lon_min=170 and geospatial_lon_max=-175 incorporates 15 degrees of longitude (ranges 170 to 180 and -180 to -175)."@en ;
                        rdfs:label "geospatial_lon_max"@en ;
                        acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_lon_min
acdd:geospatial_lon_min rdf:type owl:DatatypeProperty ;
                        rdfs:domain owl:Thing ;
                        rdfs:range xsd:double ;
                        dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lon_min> ;
                        rdfs:comment "Describes a simple longitude limit; may be part of a 2- or 3-dimensional bounding region. geospatial_lon_min specifies the westernmost longitude covered by the dataset. See also geospatial_lon_max."@en ;
                        rdfs:label "geospatial_lon_min"@en ;
                        acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_lon_resolution
acdd:geospatial_lon_resolution rdf:type owl:DatatypeProperty ;
                               rdfs:domain owl:Thing ;
                               rdfs:range xsd:string ;
                               dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lon_resolution> ;
                               rdfs:comment "Information about the targeted spacing of points in longitude. Recommend describing resolution as a number value followed by units. Examples: '100 meters', '0.1 degree'"@en ;
                               rdfs:label "geospatial_lon_resolution"@en ;
                               acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/geospatial_lon_units
acdd:geospatial_lon_units rdf:type owl:DatatypeProperty ;
                          rdfs:domain owl:Thing ;
                          rdfs:range xsd:string ;
                          dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_lon_units> ;
                          rdfs:comment "Units for the longitude axis described in \"geospatial_lon_min\" and \"geospatial_lon_max\" attributes. These are presumed to be \"degree_east\"; other options from udunits may be specified instead."@en ;
                          rdfs:label "geospatial_lon_units"@en ;
                          acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/geospatial_vertical_max
acdd:geospatial_vertical_max rdf:type owl:DatatypeProperty ;
                             rdfs:domain owl:Thing ;
                             rdfs:range xsd:double ;
                             dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_vertical_max> ;
                             rdfs:comment "Describes the numerically larger vertical limit; may be part of a 2- or 3-dimensional bounding region. See geospatial_vertical_positive and geospatial_vertical_units."@en ;
                             rdfs:label "geospatial_vertical_max"@en ;
                             acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_vertical_min
acdd:geospatial_vertical_min rdf:type owl:DatatypeProperty ;
                             rdfs:domain owl:Thing ;
                             rdfs:range xsd:double ;
                             dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_vertical_min> ;
                             rdfs:comment "Describes the numerically smaller vertical limit; may be part of a 2- or 3-dimensional bounding region. See geospatial_vertical_positive and geospatial_vertical_units."@en ;
                             rdfs:label "geospatial_vertical_min"@en ;
                             acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_vertical_positive
acdd:geospatial_vertical_positive rdf:type owl:DatatypeProperty ;
                                  rdfs:domain owl:Thing ;
                                  rdfs:range xsd:string ;
                                  dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_vertical_positive> ;
                                  rdfs:comment "One of 'up' or 'down'. If up, vertical values are interpreted as 'altitude', with negative values corresponding to below the reference datum (e.g., under water). If down, vertical values are interpreted as 'depth', positive values correspond to below the reference datum. Note that if geospatial_vertical_positive is down ('depth' orientation), the geospatial_vertical_min attribute specifies the data's vertical location furthest from the earth's center, and the geospatial_vertical_max attribute specifies the location closest to the earth's center."@en ;
                                  rdfs:label "geospatial_vertical_positive"@en ;
                                  acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/geospatial_vertical_resolution
acdd:geospatial_vertical_resolution rdf:type owl:DatatypeProperty ;
                                    rdfs:domain owl:Thing ;
                                    rdfs:range xsd:string ;
                                    dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_vertical_resolution> ;
                                    rdfs:comment "Information about the targeted vertical spacing of points. Example: '25 meters'"@en ;
                                    rdfs:label "geospatial_vertical_resolution"@en ;
                                    acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/geospatial_vertical_units
acdd:geospatial_vertical_units rdf:type owl:DatatypeProperty ;
                               rdfs:domain owl:Thing ;
                               rdfs:range xsd:string ;
                               dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#geospatial_vertical_units> ;
                               rdfs:comment "Units for the vertical axis described in \"geospatial_vertical_min\" and \"geospatial_vertical_max\" attributes. The default is EPSG:4979 (height above the ellipsoid, in meters); other vertical coordinate reference systems may be specified. Note that the common oceanographic practice of using pressure for a vertical coordinate, while not strictly a depth, can be specified using the unit bar. Examples: 'EPSG:5829' (instantaneous height above sea level), 'EPSG:5831' (instantaneous depth below sea level)."@en ;
                               rdfs:label "geospatial_vertical_units"@en ;
                               acdd:recommendationLevel acdd:Dataset_Suggested .


###  https://schema.acdd.dev/v1.3/history
acdd:history rdf:type owl:DatatypeProperty ;
             rdfs:domain owl:Thing ;
             rdfs:range xsd:string ;
             dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#history> ;
             rdfs:comment "Provides an audit trail for modifications to the original data. This attribute is also in the NetCDF Users Guide: 'This is a character array with a line for each invocation of a program that has modified the dataset. Well-behaved generic netCDF applications should append a line containing: date, time of day, user name, program name and command arguments.' To include a more complete description you can append a reference to an ISO Lineage entity; see NOAA EDM ISO Lineage guidance."@en ;
             rdfs:label "history"@en ;
             acdd:recommendationLevel acdd:Dataset_Recommended .


###  https://schema.acdd.dev/v1.3/id
acdd:id rdf:type owl:DatatypeProperty ;
        rdfs:domain owl:Thing ;
        rdfs:range xsd:string ;
        dct:source <https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3#id> ;
        rdfs:comment "An identifier for the data set, provided by and unique within its naming authority. The combination of the \"naming authority\" and the \"id\" should be globally unique, but the id can be globally unique by itself also. IDs can be URLs, URNs, DOIs, meaningful text strings, a local key, or any other unique string of characters. The id should not include white space characters."@en ;
        rdfs:label "id"@en ;
        acdd:recommendationLevel acdd:Dataset_Recommended .


