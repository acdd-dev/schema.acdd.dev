                         rdfs:range xsd:string ;
                         rdfs:comment "The smallest time step included in the resource."@en ;
                         rdfs:label "Temporal Resolution"@en ;
                         rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Temporal_Resolution> ;
