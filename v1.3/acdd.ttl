acdd:start_time rdf:type owl:DatatypeProperty ;
                rdfs:domain owl:Thing ;
                rdfs:range xsd:string ;
                rdfs:comment "The start of the bounding time period."@en ;
                rdfs:label "Start Time"@en ;
                rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Start_Time> ;
