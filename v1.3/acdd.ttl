acdd:supplemental_information rdf:type owl:DatatypeProperty ;
                              rdfs:domain owl:Thing ;
                              rdfs:range xsd:string ;
                              rdfs:comment "Miscellaneous information about the data."@en ;
                              rdfs:label "Supplemental Information"@en ;
                              rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Supplemental_Information> ;
