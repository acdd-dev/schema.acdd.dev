                      rdfs:range xsd:double ;
                      rdfs:comment "The maximum height or depth of the bounding rectangle."@en ;
                      rdfs:label "Vertical Maximum"@en ;
                      rdfs:seeAlso <https://wiki.esipfed.org/Concepts_Glossary#Vertical_Maximum> ;
