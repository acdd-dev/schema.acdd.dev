                        rdfs:label "creatorInstitution" ;
                        skos:relatedMatch acdd:creator_institution .


###  https://schema.acdd.dev/v1.3/creatorType
acdd:creatorType rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range [ rdf:type owl:Class ;
                              owl:unionOf ( owl:Thing
                                            acdd:AgentType
                                          )
                            ] ;
                 rdfs:label "creatorType" ;
                 skos:relatedMatch acdd:creator_type .


