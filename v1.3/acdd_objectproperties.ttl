@prefix : <https://schema.acdd.dev/v1.3/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix acdd: <https://schema.acdd.dev/v1.3/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@base <https://schema.acdd.dev/v1.3/> .

<https://schema.acdd.dev/v1.3/objects/> rdf:type owl:Ontology ;
                                 owl:versionIRI <https://schema.acdd.dev/v1.3/objects/> ;
                                 dct:creator "Earth Science Information Partners (ESIP)" ;
                                 dct:description "An OWL ontology encoding the ESIP Attribute Convention for Data Discovery (ACDD). It formalises the concepts, recommendation levels, and metadata properties defined at https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3."@en ;
                                 dct:license "http://www.gnu.org/copyleft/fdl.html"^^xsd:anyURI ;
                                 dct:modified "2023-09-05"^^xsd:date ;
                                 dct:source "https://wiki.esipfed.org/Attribute_Convention_for_Data_Discovery_1-3"^^xsd:anyURI ;
                                 dct:title "Attribute Convention for Data Discovery (ACDD) Ontology - ObjectProperty Extensions"@en ;
                                 vann:preferredNamespacePrefix "acdd" ;
                                 vann:preferredNamespaceUri "https://schema.acdd.dev/v1.3/" ;
                                 owl:versionInfo "1.3" .

###  http://purl.org/dc/terms/subject
dct:subject rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#relatedMatch
skos:relatedMatch rdf:type owl:AnnotationProperty .

#################################################################
#    Object Properties
#################################################################

###  https://schema.acdd.dev/v1.3/cdmDataType
acdd:cdmDataType rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range owl:Thing ;
                 rdfs:label "cdmDataType" ;
                 skos:relatedMatch acdd:cdm_data_type .


###  https://schema.acdd.dev/v1.3/contributorRole
acdd:contributorRole rdf:type owl:ObjectProperty ;
                     rdfs:domain owl:Thing ;
                     rdfs:range owl:Thing ;
                     rdfs:label "contributorRole" ;
                     skos:relatedMatch acdd:contributor_role .


###  https://schema.acdd.dev/v1.3/coverageContentType
acdd:coverageContentType rdf:type owl:ObjectProperty ;
                         rdfs:domain owl:Thing ;
                         rdfs:range owl:Thing ;
                         rdfs:label "coverageContentType" ;
                         skos:relatedMatch acdd:coverage_content_type .


###  https://schema.acdd.dev/v1.3/creatorInstitution
