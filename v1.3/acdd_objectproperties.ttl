#################################################################
#    Classes
#################################################################

###  https://schema.acdd.dev/v1.3/AgentType
acdd:AgentType rdf:type owl:Class ;
               dct:subject acdd:creator_type ,
                           acdd:publisher_type ;
               rdfs:comment "The type of Agent performing as creator or publisher of some resource." ;
               rdfs:label "AgentType" .


#################################################################
#    Individuals
#################################################################

###  https://schema.acdd.dev/v1.3/AgentType_Group
acdd:AgentType_Group rdf:type owl:NamedIndividual ,
                              acdd:AgentType ;
                     rdfs:label "group" .


###  https://schema.acdd.dev/v1.3/AgentType_Institution
acdd:AgentType_Institution rdf:type owl:NamedIndividual ,
                                    acdd:AgentType ;
                           rdfs:label "institution" .


###  https://schema.acdd.dev/v1.3/AgentType_Person
